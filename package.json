{
  "name": "bearer-auth-service",
  "version": "1.0.0",
  "description": "Bearer authentication microservice with multi-tokens",
  "license": "MIT",
  "author": "orKL3mlz",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/server.ts",
  "scripts": {
    "prepare": "npm run build",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child --ignore-watch node_modules --no-notify src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "express": "^4.21.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "tsc": "^2.0.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}